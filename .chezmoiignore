# lazy.nvim rewrites lazy-lock.json at runtime (:Lazy sync/update). Let it own
# the file per-machine instead of fighting chezmoi over it. init.lua reproduces
# the plugin set on any host; we just don't pin exact commits across machines.
.config/nvim/lazy-lock.json
{{ if not (dig "components" "zsh" true .) -}}
.zshrc
.zshenv
.zsh
{{ end -}}
{{ if not (dig "components" "tmux" true .) -}}
.tmux.conf
.tmux
{{ end -}}
{{/* notify subsystem (config + shared lib) is read by both the zsh process
     notifier and the tmux/Claude hooks; install it when either is selected. */}}
{{ if and (not (dig "components" "zsh" true .)) (not (dig "components" "tmux" true .)) -}}
.config/notify
{{ end -}}
{{ if not (dig "components" "neovim" true .) -}}
.config/nvim
{{ end -}}
{{ if not (dig "components" "git" "ignore_global" true .) -}}
.gitignore_global
{{ end -}}
{{ if not (dig "components" "ai" "claude_hooks" false .) -}}
.claude/settings.json
.claude/hooks/notify-tmux.sh
.claude/hooks/notify-clear.sh
{{ end -}}
{{ if not (dig "components" "ai" "codex_hooks" false .) -}}
.codex/config.toml
.codex/hooks/notify-tmux.sh
{{ end -}}
{{/* Ghostty config (~/.config/ghostty) is a terminal sub-feature. Cross-platform
     (macOS + Linux), default-on, so the dig default is true. Ignore unless the
     terminal > ghostty sub-feature is selected. */}}
{{ if not (dig "components" "terminal" "ghostty" true .) -}}
.config/ghostty
{{ end -}}
{{/* iterm2 Dynamic Profiles JSON (~/.config/iterm2, symlinked into ~/Library by
     install-iterm2.sh) are macOS-only and opt-in; iterm2 is now a terminal
     sub-feature. Ignore unless we are on darwin AND terminal > iterm2 is selected. */}}
{{ if or (ne .chezmoi.os "darwin") (not (dig "components" "terminal" "iterm2" false .)) -}}
.config/iterm2
{{ end -}}
