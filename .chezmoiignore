.tmux
{{ end -}}
{{ if not (dig "components" "neovim" true .) -}}
.config/nvim
{{ end -}}
{{ if not (and (dig "components" "tmux" true .) (dig "components" "ai" false .)) -}}
.tmux/conf.d/claude.conf
{{ end -}}
