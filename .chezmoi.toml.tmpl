{{- /* Component selection. Asked once at `chezmoi init` and persisted into   */ -}}
{{- /* ~/.config/chezmoi/chezmoi.toml. apply/update read the stored choice and */ -}}
{{- /* never re-prompt; re-run `chezmoi init` (or edit [data.components]) to   */ -}}
{{- /* change it. Parsed into booleans below so the rest of the repo can gate  */ -}}
{{- /* on .components.* (see .chezmoiignore, .chezmoiexternal.toml).            */ -}}
{{- /*                                                                          */ -}}
{{- /* Single source of truth: add/remove a component by editing this list.    */ -}}
{{- /* Each record is:                                                          */ -}}
{{- /*   num   the menu number the user types to select it (string).           */ -}}
{{- /*   key   the [data.components] boolean key it sets.                       */ -}}
{{- /*   label short name shown in the menu, padded for alignment.             */ -}}
{{- /*   desc  one-line description shown in the menu.                          */ -}}
{{- /*   all   whether `all` (the default-on set) includes it. `all+` always   */ -}}
{{- /*         includes everything regardless of this flag.                     */ -}}
{{- /* The menu text, the per-component parse, and the [data.components] block  */ -}}
{{- /* are all derived from this list, so a new component is a one-line add.    */ -}}
{{- $components := list
    (dict "num" "1" "key" "zsh"       "label" "zsh"       "desc" "oh-my-zsh, plugins, custom functions, aliases" "all" true)
    (dict "num" "2" "key" "tmux"      "label" "tmux"      "desc" "tmux + plugins (tpm, resurrect, sensible, yank)" "all" true)
    (dict "num" "3" "key" "neovim"    "label" "neovim"    "desc" "neovim, lazy.nvim, language servers, linters"    "all" true)
    (dict "num" "4" "key" "gitconfig" "label" "gitconfig" "desc" "copy ~/.gitconfig* from repo examples"           "all" false)
    (dict "num" "5" "key" "ai" "label" "ai" "desc" "AI tools: CodeCompanion.nvim assistant (needs neovim)" "all" false)
-}}
{{- /* Build the numbered menu text from the list. labels are padded to the    */ -}}
{{- /* width of the widest label so descriptions line up.                       */ -}}
{{- $labelWidth := 0 -}}
{{- range $components }}{{- $labelWidth = max $labelWidth (len .label) }}{{- end -}}
{{- $lines := list "Components to install:" -}}
{{- range $components -}}
{{- $lines = append $lines (printf "  %s) %s %s" .num (printf "%-*s" (int $labelWidth) .label) .desc) -}}
{{- end -}}
{{- /* Default = the numbers in the `all` set, space-joined (e.g. "1 2 3").     */ -}}
{{- /* Extras = labels NOT in the `all` set, which is what `all+` adds on top.  */ -}}
{{- $defaultNums := list -}}
{{- $extraLabels := list -}}
{{- range $components }}{{- if .all }}{{- $defaultNums = append $defaultNums .num }}{{- else }}{{- $extraLabels = append $extraLabels .label }}{{- end }}{{- end -}}
{{- $default := join " " $defaultNums -}}
{{- $extras := join ", " $extraLabels -}}
{{- $menu := join "\n" $lines -}}
{{- $menu = printf "%s\n\n  all   the default set (%s)\n  all+  everything, adds %s\n\nEnter numbers (e.g. \"1 3\"), a keyword above, or press Enter for default (%s)" $menu $default $extras $default -}}
{{- /* Interactive selection. With gum installed, show a checkbox TUI built     */ -}}
{{- /* from the same $components list (a new component appears automatically),    */ -}}
{{- /* and resolve the picks to the same numeric string the parser below wants.   */ -}}
{{- /* gum draws on the terminal and prints the chosen lines to stdout, which     */ -}}
{{- /* `output` captures; reading </dev/tty keeps it interactive under chezmoi,   */ -}}
{{- /* and `|| true` makes no-tty / cancel yield an empty pick. When gum is       */ -}}
{{- /* absent (e.g. the very first apply, before install.sh installs it) or       */ -}}
{{- /* returns nothing, fall through to the typed promptStringOnce menu below.    */ -}}
{{- /* DOTFILES_NO_GUM forces the typed menu (used by validate-templates.sh to   */ -}}
{{- /* exercise the parser deterministically, and handy to bypass the TUI).       */ -}}
{{- $sel := "" -}}
{{- if and (lookPath "gum") (not (env "DOTFILES_NO_GUM")) -}}
{{-   $opts := list -}}
{{-   range $components }}{{- $opts = append $opts (printf "%s) %s - %s" .num .label .desc | squote) -}}{{- end -}}
{{-   $hdr := "Components to install (space toggles, enter confirms):" -}}
{{- /* On re-init, hint the current selection in the header. gum's --selected   */ -}}
{{- /* splits on commas and our labels carry comma-laden descriptions, so a      */ -}}
{{- /* header hint is used instead of pre-checking.                              */ -}}
{{-   $prevSel := dig "componentSelection" "" . -}}
{{-   if ne $prevSel "" -}}
{{-     $curLabels := list -}}
{{-     range $components }}{{- if contains .num $prevSel }}{{- $curLabels = append $curLabels .label -}}{{- end -}}{{- end -}}
{{-     $hdr = printf "%s  [current: %s]" $hdr (join ", " $curLabels) -}}
{{-   end -}}
{{-   $cmd := printf "test -e /dev/tty && gum choose --no-limit --header %s %s </dev/tty || true" ($hdr | squote) (join " " $opts) -}}
{{- /* Each chosen line starts with "<num>)"; take the leading number, join.     */ -}}
{{-   $nums := list -}}
{{-   range (splitList "\n" (trim (output "sh" "-c" $cmd))) }}{{- if . }}{{- $nums = append $nums (first (splitList ")" .)) -}}{{- end -}}{{- end -}}
{{-   $sel = trim (join " " $nums) -}}
{{- end -}}
{{- if eq $sel "" -}}
{{-   $sel = trim (promptStringOnce . "componentSelection" $menu) -}}
{{- end -}}
{{- /* Empty = pressed Enter. A value starting with the menu text means a    */ -}}
{{- /* non-interactive init (no tty) echoed the prompt back; both fall to the */ -}}
{{- /* default so a piped/CI install never persists a garbage selection.      */ -}}
{{- if or (eq $sel "") (hasPrefix "Components to install" $sel) }}{{- $sel = $default }}{{- end -}}
{{- /* Keyword flags. `all+` implies everything; `all` implies the all-set.    */ -}}
{{- $allPlus := contains "all+" $sel -}}
{{- $all := contains "all" $sel -}}
{{- /* Resolve each component to a boolean by the same rule the old hardcoded  */ -}}
{{- /* parser used: selected if all+, or (all and in-all-set), or its number   */ -}}
{{- /* appears anywhere in the string. `contains` keeps spacing/order/commas   */ -}}
{{- /* irrelevant: "1 3", "13", "3 1", "1,3" are all equivalent.               */ -}}
{{- $resolved := dict -}}
{{- range $components -}}
{{- $on := or $allPlus (and $all .all) (contains .num $sel) -}}
{{- $resolved = set $resolved .key $on -}}
{{- end -}}

[data]
    componentSelection = {{ $sel | quote }}

[data.components]
{{ range $components }}    {{ .key }} = {{ get $resolved .key }}
{{ end -}}
