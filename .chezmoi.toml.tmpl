{{- /* Component selection. Asked once at `chezmoi init` and persisted into   */ -}}
{{- /* ~/.config/chezmoi/chezmoi.toml. apply/update read the stored choice and */ -}}
{{- /* never re-prompt; re-run `chezmoi init` (or edit [data.components]) to   */ -}}
{{- /* change it. Parsed into booleans below so the rest of the repo can gate  */ -}}
{{- /* on .components.* (see .chezmoiignore, .chezmoiexternal.toml).            */ -}}
{{- /*                                                                          */ -}}
{{- /* Single source of truth: add/remove a component by editing this list.    */ -}}
{{- /* Each record is:                                                          */ -}}
{{- /*   num   the menu number the user types to select it (string).           */ -}}
{{- /*   key   the [data.components] boolean key it sets.                       */ -}}
{{- /*   label short name shown in the menu, padded for alignment.             */ -}}
{{- /*   desc  one-line description shown in the menu.                          */ -}}
{{- /*   all   whether `all` (the default-on set) includes it. `all+` always   */ -}}
{{- /*         includes everything regardless of this flag.                     */ -}}
{{- /* The menu text, the per-component parse, and the [data.components] block  */ -}}
{{- /* are all derived from this list, so a new component is a one-line add.    */ -}}
{{- /* Sub-feature lists for the components that have a nested submenu (git, ai). */ -}}
{{- /* Same record shape as $components. Here `all` means "pre-selected in the    */ -}}
{{- /* submenu by default", which is also the no-tty / Enter fallback selection.   */ -}}
{{- $gitFeatures := list
    (dict "num" "1" "key" "config"        "label" "config"        "desc" "~/.gitconfig"          "all" false)
    (dict "num" "2" "key" "personal"      "label" "personal"      "desc" "~/.gitconfig.personal" "all" false)
    (dict "num" "3" "key" "ignore_global" "label" "ignore_global" "desc" "~/.gitignore_global"   "all" true)
-}}
{{- $aiFeatures := list
    (dict "num" "1" "key" "codecompanion" "label" "codecompanion" "desc" "CodeCompanion.nvim assistant (needs neovim)" "all" true)
    (dict "num" "2" "key" "claude_hooks"  "label" "claude_hooks"  "desc" "Claude settings.json notify hooks"           "all" false)
    (dict "num" "3" "key" "codex_hooks"   "label" "codex_hooks"   "desc" "Codex config.toml notify hook"               "all" false)
    (dict "num" "4" "key" "statusline"    "label" "statusline"    "desc" "Claude statusline slot (reserved)"           "all" false)
-}}
{{- /* Top-level components. git and ai carry a non-empty `sub` features list plus */ -}}
{{- /* the submenu's persisted selection key and header; the rest have an empty    */ -}}
{{- /* `sub` and are emitted as bare booleans under [data.components].             */ -}}
{{- $components := list
    (dict "num" "1" "key" "zsh"    "label" "zsh"    "desc" "oh-my-zsh, plugins, custom functions, aliases"  "all" true  "sub" (list))
    (dict "num" "2" "key" "tmux"   "label" "tmux"   "desc" "tmux + plugins (tpm, resurrect, sensible, yank)" "all" true  "sub" (list))
    (dict "num" "3" "key" "neovim" "label" "neovim" "desc" "neovim, lazy.nvim, language servers, linters"    "all" true  "sub" (list))
    (dict "num" "4" "key" "git"    "label" "git"    "desc" "git config files (config, personal, ignore_global)" "all" true  "sub" $gitFeatures "selKey" "gitSelection" "header" "git sub-features")
    (dict "num" "5" "key" "ai"     "label" "ai"     "desc" "AI tools (codecompanion, claude_hooks, codex_hooks, statusline)"  "all" false "sub" $aiFeatures  "selKey" "aiSelection"  "header" "AI sub-features")
-}}
{{- /* Build the numbered menu text from the list. labels are padded to the    */ -}}
{{- /* width of the widest label so descriptions line up.                       */ -}}
{{- $labelWidth := 0 -}}
{{- range $components }}{{- $labelWidth = max $labelWidth (len .label) }}{{- end -}}
{{- $lines := list "Components to install:" -}}
{{- range $components -}}
{{- $lines = append $lines (printf "  %s) %s %s" .num (printf "%-*s" (int $labelWidth) .label) .desc) -}}
{{- end -}}
{{- /* Default = the numbers in the `all` set, space-joined (e.g. "1 2 3").     */ -}}
{{- /* Extras = labels NOT in the `all` set, which is what `all+` adds on top.  */ -}}
{{- $defaultNums := list -}}
{{- $extraLabels := list -}}
{{- range $components }}{{- if .all }}{{- $defaultNums = append $defaultNums .num }}{{- else }}{{- $extraLabels = append $extraLabels .label }}{{- end }}{{- end -}}
{{- $default := join " " $defaultNums -}}
{{- $extras := join ", " $extraLabels -}}
{{- $menu := join "\n" $lines -}}
{{- $menu = printf "%s\n\n  all   the default set (%s)\n  all+  everything, adds %s\n\nEnter numbers (e.g. \"1 3\"), a keyword above, or press Enter for default (%s)" $menu $default $extras $default -}}
{{- /* Interactive selection. With gum installed, show a checkbox TUI built from */ -}}
{{- /* the same $components list (a new component appears automatically).        */ -}}
{{- /* gum choose --no-limit renders checkboxes; selected lines go to stdout.   */ -}}
{{- /* Reading </dev/tty keeps it interactive under chezmoi, and `|| true` makes */ -}}
{{- /* no-tty / Esc yield an empty pick. When gum is absent (e.g. the very      */ -}}
{{- /* first apply on a fresh host before install.sh runs) or returns nothing,   */ -}}
{{- /* fall through to the typed promptStringOnce menu below.                    */ -}}
{{- /* DOTFILES_NO_TUI forces the typed menu (used by validate-templates.sh to  */ -}}
{{- /* exercise the parser deterministically, and handy to bypass the TUI).      */ -}}
{{- $sel := "" -}}
{{- if and (lookPath "gum") (not (env "DOTFILES_NO_TUI")) -}}
{{-   $opts := list -}}
{{-   range $components }}{{- $opts = append $opts (printf "%s) %s - %s" .num .label .desc | squote) -}}{{- end -}}
{{-   $hdr := "Components to install  (space toggles, enter confirms, esc cancels):" -}}
{{- /* On re-init, hint the current selection in the header.                     */ -}}
{{-   $prevSel := dig "componentSelection" "" . -}}
{{-   if ne $prevSel "" -}}
{{-     $curLabels := list -}}
{{-     range $components }}{{- if contains .num $prevSel }}{{- $curLabels = append $curLabels .label -}}{{- end -}}{{- end -}}
{{-     $hdr = printf "%s  [current: %s]" $hdr (join ", " $curLabels) -}}
{{-   end -}}
{{-   $cmd := printf "test -e /dev/tty && gum choose --no-limit --header %s %s </dev/tty 2>/dev/tty || true" ($hdr | squote) (join " " $opts) -}}
{{- /* Each chosen line starts with "<num>)"; take the leading number, join.     */ -}}
{{-   $nums := list -}}
{{-   range (splitList "\n" (trim (output "sh" "-c" $cmd))) }}{{- if . }}{{- $nums = append $nums (first (splitList ")" .)) -}}{{- end -}}{{- end -}}
{{-   $sel = trim (join " " $nums) -}}
{{- end -}}
{{- if eq $sel "" -}}
{{-   $sel = trim (promptStringOnce . "componentSelection" $menu) -}}
{{- end -}}
{{- /* Empty = pressed Enter. A value starting with the menu text means a    */ -}}
{{- /* non-interactive init (no tty) echoed the prompt back; both fall to the */ -}}
{{- /* default so a piped/CI install never persists a garbage selection.      */ -}}
{{- if or (eq $sel "") (hasPrefix "Components to install" $sel) }}{{- $sel = $default }}{{- end -}}
{{- /* Keyword flags. `all+` implies everything; `all` implies the all-set.    */ -}}
{{- $allPlus := contains "all+" $sel -}}
{{- $all := contains "all" $sel -}}
{{- /* Build the SET of selected component numbers from $sel. Split on          */ -}}
{{- /* whitespace and commas into tokens; a token that exactly matches a         */ -}}
{{- /* component number selects that component. A pure-digit token that is NOT   */ -}}
{{- /* itself a component number expands into its individual digits, so the      */ -}}
{{- /* no-space shorthand "13" still means 1 and 3 - while a real two-digit      */ -}}
{{- /* number ("10", once a 10th component exists) matches component 10 instead  */ -}}
{{- /* of substring-matching component 1. Spacing/order/commas stay irrelevant:  */ -}}
{{- /* "1 3", "13", "3 1", "1,3" are equivalent.                                 */ -}}
{{- $compNums := list -}}
{{- range $components }}{{- $compNums = append $compNums .num -}}{{- end -}}
{{- $selSet := dict -}}
{{- range (splitList " " (trim (replace "," " " $sel))) -}}
{{-   if ne . "" -}}
{{-     if has . $compNums -}}
{{-       $selSet = set $selSet . true -}}
{{-     else if regexMatch "^[0-9]+$" . -}}
{{-       range (splitList "" .) }}{{- $selSet = set $selSet . true -}}{{- end -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- /* Resolve each component: on if all+, or (all and in-all-set), or selected. */ -}}
{{- $resolved := dict -}}
{{- range $components -}}
{{- $on := or $allPlus (and $all .all) (hasKey $selSet .num) -}}
{{- $resolved = set $resolved .key $on -}}
{{- end -}}
{{- /* Nested submenus. For each top-level component that is ON and has a `sub`  */ -}}
{{- /* features list (git, ai), pick its sub-features. Mirrors the top menu: a    */ -}}
{{- /* gum checkbox TUI when available, else a typed promptStringOnce; no-tty /    */ -}}
{{- /* DOTFILES_NO_TUI / Enter falls back to the `all`-flagged sub-defaults. gum   */ -}}
{{- /* submenu options start with the feature key and avoid newer flags such as    */ -}}
{{- /* --label-delimiter, so Debian-packaged gum builds work too. --selected gets */ -}}
{{- /* full option strings; stdout is parsed back to the leading key. The resolve  */ -}}
{{- /* accepts either keys (gum) or numbers (typed) via `contains`.                */ -}}
{{- $subResolved := dict -}}
{{- $subSelStore := dict -}}
{{- /* range rebinds `.` to the element, so capture the root data for dig /     */ -}}
{{- /* promptStringOnce (which must read the persisted [data] selection keys).   */ -}}
{{- $root := . -}}
{{- range $c := $components -}}
{{-   if gt (len $c.sub) 0 -}}
{{-     $feats := $c.sub -}}
{{-     $subDefaultKeys := list -}}
{{-     range $feats }}{{ if .all }}{{ $subDefaultKeys = append $subDefaultKeys .key }}{{ end }}{{ end -}}
{{-     $subDefault := join " " $subDefaultKeys -}}
{{-     $r := dict -}}
{{-     $stored := "" -}}
{{-     if get $resolved $c.key -}}
{{-       $subSel := "" -}}
{{- /* `all` / `all+` take the sub-defaults without prompting (the guard below   */ -}}
{{- /* defaults an empty $subSel); only an explicit per-number selection prompts. */ -}}
{{-       if not (or $all $allPlus) -}}
{{-       if and (lookPath "gum") (not (env "DOTFILES_NO_TUI")) -}}
{{-         $prevSub := dig $c.selKey "" $root -}}
{{-         $seedOpts := list -}}
{{-         if eq $prevSub "" -}}
{{-           range $feats }}{{ if .all }}{{ $seedOpts = append $seedOpts (printf "%s - %s" .key .desc) }}{{ end }}{{ end -}}
{{-         else -}}
{{-           range $feats }}{{ if or (contains .key $prevSub) (contains .num $prevSub) }}{{ $seedOpts = append $seedOpts (printf "%s - %s" .key .desc) }}{{ end }}{{ end -}}
{{-         end -}}
{{-         $subOpts := list -}}
{{-         range $feats }}{{ $subOpts = append $subOpts (printf "%s - %s" .key .desc | squote) }}{{ end -}}
{{-         $subHdr := printf "%s  (space toggles, enter confirms, esc cancels):" $c.header -}}
{{-         $subCmd := printf "test -e /dev/tty && gum choose --no-limit --selected=%s --header %s %s </dev/tty 2>/dev/tty || true" (join "," $seedOpts | squote) ($subHdr | squote) (join " " $subOpts) -}}
{{-         $picked := list -}}
{{-         range (splitList "\n" (trim (output "sh" "-c" $subCmd))) }}{{ if . }}{{ $picked = append $picked (first (splitList " " .)) }}{{ end }}{{ end -}}
{{-         $subSel = trim (join " " $picked) -}}
{{-       end -}}
{{-       if eq $subSel "" -}}
{{-         $subLines := list (printf "%s (enter numbers or keys):" $c.header) -}}
{{-         range $feats }}{{ $subLines = append $subLines (printf "  %s) %s - %s" .num .label .desc) }}{{ end -}}
{{-         $subPrompt := printf "%s\n\nEnter (e.g. \"1 3\"), or press Enter for default (%s)" (join "\n" $subLines) $subDefault -}}
{{-         $subSel = trim (promptStringOnce $root $c.selKey $subPrompt) -}}
{{-       end -}}
{{-       end -}}
{{-       if or (eq $subSel "") (hasPrefix $c.header $subSel) }}{{ $subSel = $subDefault }}{{ end -}}
{{-       range $feats }}{{ $r = set $r .key (or (contains .key $subSel) (contains .num $subSel)) }}{{ end -}}
{{-       $stored = $subSel -}}
{{-     else -}}
{{-       range $feats }}{{ $r = set $r .key false }}{{ end -}}
{{-     end -}}
{{-     $subResolved = set $subResolved $c.key $r -}}
{{-     $subSelStore = set $subSelStore $c.key $stored -}}
{{-   end -}}
{{- end -}}

[data]
    componentSelection = {{ $sel | quote }}
    gitSelection = {{ get $subSelStore "git" | quote }}
    aiSelection = {{ get $subSelStore "ai" | quote }}

[data.components]
{{ range $components }}{{ if eq (len .sub) 0 }}    {{ .key }} = {{ get $resolved .key }}
{{ end }}{{ end }}
[data.components.git]
{{ range $gitFeatures }}    {{ .key }} = {{ get (get $subResolved "git") .key }}
{{ end }}
[data.components.ai]
{{ range $aiFeatures }}    {{ .key }} = {{ get (get $subResolved "ai") .key }}
{{ end -}}
