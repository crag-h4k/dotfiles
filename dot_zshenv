export ZSH_BASE=$HOME/.zsh
export ZSH_CUSTOM=$ZSH_BASE/custom
export ZSH=$ZSH_BASE/ohmyzsh
export PATH=$ZSH_BASE/bin:$PATH
export PATH=$HOME/.local/bin:$PATH
export PATH=$HOME/.private-bin:$PATH
export PATH=/usr/local/bin:$PATH
export PATH=/usr/sbin:$PATH
# Max and Mojo Environment
export MAX_PATH=$HOME/.modular/pkg/packages.modular.com_max
export MODULAR_HOME=$HOME/.modular
export PATH=$MAX_PATH/bin:$PATH

export LANG="en_US.UTF-8"
# GPG_TTY moved to .zshrc (interactive only): $(tty) is meaningless for the
# non-interactive shells that also source .zshenv. TERM is left to the
# terminal emulator / tmux to negotiate (tmux.conf sets tmux-256color).
export UPDATE_ZSH_DAYS=7
export HISTTIMEFORMAT="%d-%b-%y %*"
export ARCH="$(arch)"
#
case "$OSTYPE" in
    darwin*)
        export PATH=$HOME/.vpn:$PATH
        export HOMEBREW_PREFIX=/opt/homebrew
        export HOMEBREW_CELLAR=/opt/homebrew/Cellar
        export HOMEBREW_REPOSITORY=/opt/homebrew
        export PATH=/opt/homebrew/bin:/opt/homebrew/sbin:$PATH
        export MANPATH=/opt/homebrew/share/man${MANPATH+:$MANPATH}:
        export INFOPATH=/opt/homebrew/share/info:${INFOPATH:-}
        export OLLAMA_ORIGINS="app://obsidian.md*"
        # export PATH=/opt/homebrew/opt/openjdk/bin:$PATH
        # export CPPFLAGS="-I/opt/homebrew/opt/openjdk/include"
        # macOS is arm64-only here (no Intel Macs in use); run act with amd64 images.
        alias "act"="act --container-architecture linux/amd64"
        ;;
    linux*)
        # CONDA_PATH is consumed by the conda init block in
        # custom/functions/conda_env.zsh, which activates conda correctly via
        # its conda.sh hook. Do NOT add $CONDA_PATH to PYTHONPATH: the root dir
        # is not a site-packages path, so it makes nothing importable and just
        # pollutes every (including non-interactive) python invocation.
        export CONDA_PATH=/opt/miniconda3
        export PATH=/snap/bin:$PATH
        export PATH=/opt/bin:$PATH
        export PATH=/opt/miniconda3/bin:$PATH
        export PATH=/usr/local/go/bin:$PATH
        ;;
esac

# Collapse duplicate PATH entries (keeps first occurrence). Prevents bloat from
# re-sourcing (`sourcez`) and stops a stray snap/conda binary from shadowing one
# installed to /usr/local/bin.
typeset -U path PATH

# fpath resilience. When FPATH is present in the environment, zsh seeds fpath
# from it and REPLACES (does not merge) its own function dirs. An exported FPATH
# inherited from a long-lived parent - e.g. a tmux server started under a zsh
# that Homebrew has since upgraded - then still points at the deleted
# Cellar/zsh/<old>/functions dir and omits the running zsh's, so autoload of the
# core functions (compinit, add-zsh-hook, is-at-least, colors, bashcompinit)
# fails and floods every shell with "function definition file not found". Ensure
# the running zsh's own functions dir is on fpath, de-dupe, and un-export FPATH so
# child shells re-derive their own instead of inheriting a stale one. The loop is
# idempotent - if the dir is already present, the prepend is collapsed by the
# `typeset -U` below.
() {
    local d
    for d in \
        $HOMEBREW_PREFIX/share/zsh/functions(N) \
        /usr/share/zsh/$ZSH_VERSION/functions(N) \
        /usr/share/zsh/functions(N) \
        ${${:-${commands[zsh]:A}}:h:h}/share/zsh/$ZSH_VERSION/functions(N)
    do
        if [[ -e $d/add-zsh-hook ]]; then
            fpath=($d $fpath)
            break
        fi
    done
}
typeset -U fpath
typeset +x FPATH
