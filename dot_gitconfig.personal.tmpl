# Personal git identity. Values stored in ~/.config/chezmoi/chezmoi.toml.
# To update: edit that file and run `chezmoi apply`.

[user]
    name  = {{ .gitName }}
    email = {{ .gitEmail }}

# Optional. Set if you use a dedicated SSH key for git pushes:
# [core]
#     sshCommand = "ssh -i ~/.ssh/your-key-name"

# Optional. Sets your GitHub username (used by some tools):
# [github]
#     user = ""
