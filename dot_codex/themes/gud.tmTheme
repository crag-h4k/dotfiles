<?xml version="1.0" encoding="UTF-8"?>
<!--
  ~/.codex/themes/gud.tmTheme
  gud (Dracula-family) TextMate theme for the Codex CLI TUI. Drop into
  ~/.codex/themes/ and select with `tui.theme = "gud"` (the filename stem).
  Codex derives its UI palette from these TextMate scope colors, so this file is
  Codex's analogue of the terminal's gud-theme.conf: the accent scopes carry the
  gud accents (identical hexes to gud's ANSI palette) and the global background /
  foreground / caret are pinned to gud's #1E1F29 / #E6E6E6 / #BBBBBB (NOT classic
  Dracula #282a36 / #f8f8f2), so Codex matches the terminal and the Claude line.
-->
