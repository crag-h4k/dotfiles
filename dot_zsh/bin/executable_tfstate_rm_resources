#!/usr/bin/env zsh
# Remove terraform state resources listed in a file (one address per line).
# -d does a dry run (print what would be removed).

# Default values
dry_run=false

# Parse command-line arguments
while getopts ":dh" opt; do
  case "$opt" in
    d)
      dry_run=true
      ;;
    h)
      echo "Usage: tfstate_rm_resources <input_file> [-d]"
      exit 0
      ;;
    \?)
      echo "Invalid option: -$OPTARG"
      exit 1
      ;;
    :)
      echo "Option -$OPTARG requires an argument."
      exit 1
      ;;
  esac
done

# Shift off the options
shift "$((OPTIND - 1))"

# Check if the input file exists
if [[ -z "$1" ]]; then
  echo "Error: Input file not specified."
  exit 1
fi

if [[ ! -f "$1" ]]; then
  echo "Error: Input file '$1' not found."
  exit 1
fi

# Iterate through each line (one resource address per line) in the input file
while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  if $dry_run; then
    echo "Dry run: Would remove resource: $line"
  else
    # `terraform state rm` takes the address directly (there is no -name flag).
    if ! terraform state rm "$line"; then
      echo "Error removing resource: $line"
    fi
  fi
done < "$1"

echo "Terraform resource removal complete."
