#!/usr/bin/env python3
# chezmoi modify_ template for ~/.claude/settings.json.
# Rendered by chezmoi (Go template) into a Python merge script, then run with the
# current file on stdin; the merged result is emitted on stdout. Merge-only and
# idempotent: it asserts only the keys it owns and preserves model / effortLevel /
# enabledPlugins / editorMode and anything else Claude Code writes here. Stable
# across `chezmoi apply` runs.
#
# Two independent, gated injections:
#   ai > claude_hooks : the tmux attention-notification hooks + managed env.
#   ai > statusline   : the dotfiles statusline command (statusLine is ours to own;
#                       Claude never writes it, so assert it canonically).
# The file is managed when EITHER sub-feature is on (see .chezmoiignore); each
# block below is compiled in only for its sub-feature, so a statusline-only host
# gets no notify hooks and a hooks-only host gets no statusLine.
import json
import sys

try:
    data = json.load(sys.stdin)
    if not isinstance(data, dict):
        data = {}
except Exception:
    data = {}
{{ if dig "components" "ai" "claude_hooks" false . }}
hooks = data.setdefault("hooks", {})


def ensure(event, command, matcher=None):
    """Add a command hook under `event`, optionally scoped to `matcher`.

    Idempotent: a no-op if a group already carries this command (for the same
    matcher, when one is given). A Notification hook with no matcher matches
    every notification type (permission prompt, idle, MCP elicitation).
    """
    entries = hooks.setdefault(event, [])
    for group in entries:
        if matcher is not None and group.get("matcher") != matcher:
            continue
        for h in group.get("hooks", []):
            if h.get("command") == command:
                return
    group = {"hooks": [{"type": "command", "command": command}]}
    if matcher is not None:
        group = {"matcher": matcher,
                 "hooks": [{"type": "command", "command": command}]}
    entries.append(group)


ensure("Stop", "~/.claude/hooks/notify-tmux.sh")
ensure("Notification", "~/.claude/hooks/notify-tmux.sh")
# AskUserQuestion emits no Notification event, so flag it via its tool call.
ensure("PreToolUse", "~/.claude/hooks/notify-tmux.sh", matcher="AskUserQuestion")
ensure("UserPromptSubmit", "~/.claude/hooks/notify-clear.sh")

# CLAUDE_CODE_DISABLE_MOUSE_CLICKS removed: it only suppressed click *handling*
# while leaving mouse *reporting* on, so the fullscreen TUI still captured drags
# and terminal text selection never worked. The real fix is tui:default (inline),
# where Claude doesn't capture the mouse at all. Pop the stale key (merge-only, so
# only our key is touched) so `chezmoi apply` clears it from any host that still
# has it, and drop the env block if it's left empty.
env = data.get("env")
if isinstance(env, dict):
    env.pop("CLAUDE_CODE_DISABLE_MOUSE_CLICKS", None)
    if not env:
        data.pop("env", None)
{{ end }}
{{ if dig "components" "ai" "statusline" false . }}
# statusLine is ours to own (Claude never writes it), so assert it canonically
# rather than setdefault. Points at the dotfiles renderer; padding 0 = flush left.
data["statusLine"] = {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 0,
}
{{ end }}
sys.stdout.write(json.dumps(data, indent=2) + "\n")
