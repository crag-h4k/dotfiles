[core]
    excludesfile = ~/.gitignore_global
    editor = nvim
[diff]
    tool = nvimdiff
[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true
    default = current

[alias]
   showtrackedignored = ls-files -i --exclude-standard

[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto

[user]
    useConfigOnly = true

# Personal identity by default.
[include]
    path = ~/.gitconfig.personal

# Optional per-context override. Uncomment and adapt as needed:
#   [includeIf "gitdir:~/work/**"]
#       path = ~/.gitconfig.work

# If git has auth issues with ssh-agent, run: killall ssh-agent
{{- if eq .chezmoi.os "darwin" }}
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
{{- else if eq .chezmoi.os "linux" }}
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
{{- end }}
