{{- define "dotfiles-iterm-color" -}}
{{- $hex := trimPrefix "#" . -}}
{
  "Blue Component": {{ divf (int (printf "0x%s" (substr 4 6 $hex))) 255 }},
  "Color Space": "sRGB",
  "Green Component": {{ divf (int (printf "0x%s" (substr 2 4 $hex))) 255 }},
  "Red Component": {{ divf (int (printf "0x%s" (substr 0 2 $hex))) 255 }}
}
{{- end -}}
